# Frontend build-time environment (Vite). Copy to .env and adjust.
# These are baked into the bundle at `npm run build` — rebuild after changing.

# Base URL of the API the SPA talks to (no trailing slash)
VITE_API_URL=https://api.eroderunnersclub.com

# DEPRECATED: legacy name for the same value, kept as a fallback while old
# code paths still read it. Prefer VITE_API_URL.
VITE_SUPABASE_URL=https://api.eroderunnersclub.com
