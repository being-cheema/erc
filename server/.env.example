# Server environment. Copy to server/.env, fill in real values, chmod 600.
# Never commit server/.env — it holds production secrets.

# --- Database ---
# Connection string the API uses. Inside docker compose the host is `postgres`;
# from the VPS shell use 127.0.0.1:5433 (the published port).
DATABASE_URL=postgres://erode_runner:change-me-db-password@postgres:5432/erode_runners
# Used by the docker compose postgres service to create the database
POSTGRES_DB=erode_runners
POSTGRES_USER=erode_runner
POSTGRES_PASSWORD=change-me-db-password

# --- Server ---
# Port the Express API listens on (nginx proxies to 127.0.0.1:3001)
PORT=3001
# Set to `production` on the VPS (enables strict env validation, disables dev routes)
NODE_ENV=production

# --- Auth & crypto ---
# Secret for signing JWTs — 32+ random bytes (openssl rand -hex 32). Rotating it logs everyone out.
JWT_SECRET=change-me-random-hex
# 64 hex chars (32 bytes) used to encrypt Strava tokens at rest (openssl rand -hex 32). Required in production.
TOKEN_ENCRYPTION_KEY=change-me-64-hex-chars

# --- Strava API (https://www.strava.com/settings/api) ---
STRAVA_CLIENT_ID=12345
STRAVA_CLIENT_SECRET=change-me-strava-secret
# Token echoed back during webhook subscription validation (GET handshake). Required in production.
STRAVA_WEBHOOK_VERIFY_TOKEN=change-me-verify-token
# Random path segment for the webhook URL (POST /webhook/<this>) — 32+ hex chars. Required in production;
# changing it requires re-registering the Strava push subscription (see docs/PRODUCTION_RUNBOOK.md).
STRAVA_WEBHOOK_PATH_SECRET=change-me-random-hex

# --- App links ---
# Public SPA origin, used in password-reset email links
APP_URL=https://app.eroderunnersclub.com

# --- SMTP (password reset emails; Gmail app password works at this scale) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=change-me-app-password
# From header for outgoing mail
SMTP_FROM=Erode Runners Club <noreply@eroderunnersclub.com>
